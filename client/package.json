{
  "name": "@kapong/zrtc",
  "version": "0.1.0",
  "description": "Anonymous one-time P2P WebRTC connections via Cloudflare Workers",
  "type": "module",
  "main": "dist/zrtc.js",
  "module": "dist/zrtc.js",
  "exports": {
    ".": {
      "import": "./dist/zrtc.js",
      "default": "./dist/zrtc.js"
    }
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "esbuild src/index.js --format=esm --bundle --outfile=dist/zrtc.js",
    "build:min": "esbuild src/index.js --format=esm --bundle --minify --outfile=dist/zrtc.min.js",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "tiny-simple-peer": "^10.1.2"
  },
  "devDependencies": {
    "esbuild": "^0.25.0"
  },
  "keywords": ["p2p", "webrtc", "anonymous", "cloudflare-workers", "signalling"],
  "license": "MIT"
}
